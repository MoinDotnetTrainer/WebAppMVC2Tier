
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <title>@ViewData["Title"] - MyMVCApp</title>

    <!-- Bootstrap 5 CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
          rel="stylesheet">

    <!-- Bootstrap Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css"
          rel="stylesheet">

    <style>
        body {
            background-color: #f5f7fb;
        }

        .navbar-brand {
            font-weight: 700;
        }

        .sidebar {
            min-height: calc(100vh - 56px);
            background: #212529;
        }

            .sidebar a {
                color: #adb5bd;
                padding: 12px 15px;
                display: block;
                text-decoration: none;
                transition: 0.3s;
            }

                .sidebar a:hover {
                    background: #343a40;
                    color: #fff;
                }

        .content-wrapper {
            padding: 25px;
        }

        footer {
            background: #fff;
            border-top: 1px solid #dee2e6;
        }
    </style>
</head>
<body>

    <!-- Navbar -->
    <nav class="navbar navbar-expand-lg navbar-dark bg-primary shadow-sm">
        <div class="container-fluid">
            <a class="navbar-brand" href="#">
                MyMVCApp
            </a>

            <button class="navbar-toggler"
                    type="button"
                    data-bs-toggle="collapse"
                    data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse"
                 id="navbarNav">

                <ul class="navbar-nav ms-auto">
                    <li class="nav-item">
                        <a class="nav-link active" asp-action="Homepage" asp-controller="usersops">
                            Home
                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link" asp-action="Validations" asp-controller="usersops">
                            Validations
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-action="Page1" asp-controller="Statetechnique">
                            State Ex
                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link" href="#">
                            test 
                        </a>
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    <!-- Main Layout -->
    <div class="container-fluid">
        <div class="row">

            <!-- Sidebar -->
            <div class="col-md-2 p-0 sidebar">

                <a href="#">
                    <i class="bi bi-speedometer2"></i> Dashboard
                </a>

                <a href="#">
                    <i class="bi bi-people"></i> Users
                </a>

                <a href="#">
                    <i class="bi bi-box"></i> Products
                </a>

                <a href="#">
                    <i class="bi bi-gear"></i> Settings
                </a>

            </div>

            <!-- Page Content -->
            <div class="col-md-10">
                <div class="content-wrapper">

                    <!-- RenderBody -->
                    @RenderBody()

                </div>
            </div>

        </div>
    </div>

    <!-- Footer -->
    <footer class="text-center py-3 mt-auto">
        <div class="container">
            <small>
                © @DateTime.Now.Year MyMVCApp. All rights reserved.
            </small>
        </div>
    </footer>

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)


</body>
</html>