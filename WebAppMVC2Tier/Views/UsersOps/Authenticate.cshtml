@using DAlayer.Models
@model LoginModel 

@{
    ViewData["Title"] = "Authenticate";
}
<!-- Bootstrap 5 CSS -->
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
      rel="stylesheet" />
<style>
    body {
        background: linear-gradient(135deg, #4e73df, #224abe);
        height: 100vh;
    }

    .login-card {
        border-radius: 15px;
        overflow: hidden;
    }

    .login-image {
        background: url('https://images.unsplash.com/photo-1522202176988-66273c2fd55f?q=80&w=1200&auto=format&fit=crop') center/cover no-repeat;
        min-height: 500px;
    }

    .form-control {
        border-radius: 10px;
        padding: 12px;
    }

    .btn-login {
        border-radius: 10px;
        padding: 10px;
        font-weight: 600;
    }
</style>


<div class="container h-100">
    <div class="row justify-content-center align-items-center h-100">
        <div class="col-lg-10">
            <div class="card shadow-lg border-0 login-card">
                <div class="row g-0">

                    <!-- Left Image -->
                    <div class="col-md-6 d-none d-md-block login-image"></div>

                    <!-- Right Form -->
                    <div class="col-md-6 bg-white p-5">
                        <div class="text-center mb-4">
                            <h2 class="fw-bold">Welcome Back</h2>
                            <p class="text-muted">Login to your account</p>
                        </div>

                        <form asp-action="Authenticate">
                            <div class="mb-3">
                                 <label class="form-label">Email Address</label>
                                <input type="email"
                                       class="form-control"
                                       placeholder="Enter email"  asp-for="Email"/>
                            </div>

                            <div class="mb-3">
                                <label class="form-label">Password</label>
                                <input type="password"
                                       class="form-control" asp-for="Password"
                                       placeholder="Enter password" />
                            </div>

                            <div class="d-flex justify-content-between mb-4">
                               
                                <a href="#" class="text-decoration-none">
                                    Forgot Password?
                                </a>
                            </div>

                            <button type="submit" class="btn btn-primary w-100 btn-login">
                                Login
                            </button>

                            <div class="text-center mt-4">
                                <p class="mb-0">
                                    Don't have an account?
                                    <a href="#" class="text-decoration-none fw-semibold">
                                        Register
                                    </a>
                                </p>
                            </div>
                        </form>

                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

